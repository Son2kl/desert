# Telegram Bot — уведомления о заказах
# 1. Создайте бота через @BotFather в Telegram -> получите TELEGRAM_BOT_TOKEN
# 2. Добавьте бота в канал/группу и получите TELEGRAM_CHAT_ID
#    (или отправьте боту /start и получите chat_id через /getUpdates)
TELEGRAM_BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# Google Sheets — меню дня
# Инструкция: Файл -> Поделиться -> Опубликовать в интернете -> CSV -> скопировать ссылку
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv

# URL сайта (для sitemap и OpenGraph)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
